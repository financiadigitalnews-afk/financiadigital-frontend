{
  "framework": "vite",
  "rewrites": [
    {
      "source": "/article/:id",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": "(?i).*(facebookexternalhit|whatsapp|twitterbot|linkedinbot|telegrambot|discordbot|slackbot|pinterest|skypeuripreview).*"
        }
      ],
      "destination": "/api/article-og/:id"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
